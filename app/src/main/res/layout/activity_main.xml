<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:id="@+id/contenedorExplorador"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/listViewArchivos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/layoutBarraInferior"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="48dp" android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:elevation="4dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/txtRutaActual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ruta: /storage"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btnScreenOff"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_screen_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Apagar Pantalla" />

            <ImageButton
                android:id="@+id/btnInicio"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_home_custom"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Ir a Inicio" />

            <ImageButton
                android:id="@+id/btnConfiguracion"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Configuración" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/contenedorVideo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:surface_type="texture_view"
            android:background="#000000" />

        <!-- Capa de Pantalla Apagada / Visualizador (Modo Música) -->
        <RelativeLayout
            android:id="@+id/capaPantallaApagada"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false"
            android:padding="20dp">

            <!-- Contenedor Principal Horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Columna Izquierda: Título, Arte (GIGANTE) y Archivo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingEnd="15dp">

                    <TextView
                        android:id="@+id/txtMusicTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TRACK: UNKNOWN"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textAllCaps="true"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:id="@+id/imgAlbumArt"
                        android:layout_width="320dp"
                        android:layout_height="320dp"
                        android:src="@drawable/ic_home_custom"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_background"
                        android:padding="4dp"
                        android:elevation="10dp" />

                    <TextView
                        android:id="@+id/txtMusicFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="FILE: -"
                        android:textColor="#66FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed-light"
                        android:gravity="center"
                        android:ellipsize="middle"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Columna Derecha: Información y Visualizador (Esquina Inferior) -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.8"
                    android:paddingStart="20dp">

                    <!-- Metadatos alineados al centro vertical -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/txtMusicArtist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ARTIST: -"
                            android:textColor="#BBBBBB"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-condensed"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/txtMusicAlbum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="ALBUM: -"
                            android:textColor="#BBBBBB"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-condensed"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/txtMusicYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="YEAR: -"
                            android:textColor="#BBBBBB"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-condensed"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/txtMusicGenre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="GENRE: -"
                            android:textColor="#BBBBBB"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-condensed"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/txtMusicBitrate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="BITRATE: -"
                            android:textColor="#88FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-condensed-light" />
                    </LinearLayout>

                    <!-- Visualizador Dinámico: Abajo a la derecha -->
                    <LinearLayout
                        android:id="@+id/layoutVisualizer"
                        android:layout_width="wrap_content"
                        android:layout_height="70dp"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        <View android:id="@+id/bar1" android:layout_width="8dp" android:layout_height="20dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar2" android:layout_width="8dp" android:layout_height="35dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar3" android:layout_width="8dp" android:layout_height="50dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar4" android:layout_width="8dp" android:layout_height="65dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar5" android:layout_width="8dp" android:layout_height="50dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar6" android:layout_width="8dp" android:layout_height="35dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                        <View android:id="@+id/bar7" android:layout_width="8dp" android:layout_height="20dp" android:background="#BB86FC" android:layout_margin="3dp"/>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:text="AUDIO TREE PLAYER PRO"
                android:textColor="#11FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.5" />

        </RelativeLayout>

        <!-- Capa de Zonas de Toque: Ahora dentro del contenedor pero antes de los controles -->
        <LinearLayout
            android:id="@+id/capaZonasToque"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:visibility="gone">

            <View
                android:id="@+id/zonaIzquierda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />

            <View
                android:id="@+id/zonaCentro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />

            <View
                android:id="@+id/zonaDerecha"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtNombreVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="10dp"
            android:background="#80000000"
            android:text="Nombre del video"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Barra de Progreso y Tiempos: Puesta AL FINAL para que esté sobre las zonas de toque -->
        <LinearLayout
            android:id="@+id/layoutProgreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#80000000"
            android:padding="8dp"
            android:visibility="gone"
            android:elevation="20dp">

            <SeekBar
                android:id="@+id/seekBarVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="15dp"
                android:paddingEnd="15dp">

                <TextView
                    android:id="@+id/txtTiempoActual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_shuffle"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Aleatorio"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/txtTiempoRestante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Iconos de Feedback -->
        <ImageView
            android:id="@+id/imgFeedback"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="60dp"
            android:background="@drawable/circle_background"
            android:padding="15dp"
            app:tint="#FFFFFF"
            android:visibility="gone"
            android:elevation="15dp"
            android:contentDescription="Feedback" />

        <!-- Barra de Volumen Vertical (Izquierda) -->
        <ProgressBar
            android:id="@+id/pbVolumen"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="150dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="-60dp"
            android:rotation="-90"
            android:progressTint="#2196F3"
            android:background="#44000000"
            android:visibility="gone"
            android:elevation="25dp" />

        <!-- Barra de Brillo Vertical (Derecha) -->
        <ProgressBar
            android:id="@+id/pbBrillo"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="150dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="-60dp"
            android:rotation="-90"
            android:progressTint="#FFC107"
            android:background="#44000000"
            android:visibility="gone"
            android:elevation="25dp" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>