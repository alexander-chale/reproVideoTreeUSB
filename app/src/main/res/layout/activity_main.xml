<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:id="@+id/contenedorExplorador"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/listViewArchivos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/layoutBarraInferior"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="48dp" android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:elevation="4dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/txtRutaActual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ruta: /storage"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btnInicio"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_home_custom"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Ir a Inicio" />

            <ImageButton
                android:id="@+id/btnConfiguracion"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Configuración" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/contenedorVideo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:surface_type="texture_view"
            android:background="#000000" />

        <!-- Capa de Zonas de Toque: Ahora dentro del contenedor pero antes de los controles -->
        <LinearLayout
            android:id="@+id/capaZonasToque"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:visibility="gone">

            <View
                android:id="@+id/zonaIzquierda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />

            <View
                android:id="@+id/zonaCentro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />

            <View
                android:id="@+id/zonaDerecha"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtNombreVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="10dp"
            android:background="#80000000"
            android:text="Nombre del video"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Barra de Progreso y Tiempos: Puesta AL FINAL para que esté sobre las zonas de toque -->
        <LinearLayout
            android:id="@+id/layoutProgreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#80000000"
            android:padding="8dp"
            android:visibility="gone"
            android:elevation="20dp">

            <SeekBar
                android:id="@+id/seekBarVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="15dp"
                android:paddingEnd="15dp">

                <TextView
                    android:id="@+id/txtTiempoActual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_shuffle"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Aleatorio"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/txtTiempoRestante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Iconos de Feedback -->
        <ImageView
            android:id="@+id/imgFeedback"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="60dp"
            android:background="@drawable/circle_background"
            android:padding="15dp"
            app:tint="#FFFFFF"
            android:visibility="gone"
            android:elevation="15dp"
            android:contentDescription="Feedback" />

        <!-- Barra de Volumen Vertical (Izquierda) -->
        <ProgressBar
            android:id="@+id/pbVolumen"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="150dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="-60dp"
            android:rotation="-90"
            android:progressTint="#2196F3"
            android:background="#44000000"
            android:visibility="gone"
            android:elevation="25dp" />

        <!-- Barra de Brillo Vertical (Derecha) -->
        <ProgressBar
            android:id="@+id/pbBrillo"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="150dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="-60dp"
            android:rotation="-90"
            android:progressTint="#FFC107"
            android:background="#44000000"
            android:visibility="gone"
            android:elevation="25dp" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>