<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Selector de Modo a Editar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp"
            android:background="#22FFFFFF"
            android:padding="8dp">
            <TextView
                android:id="@+id/lblEditMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/config_edit_mode"
                android:textColor="#BB86FC"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginEnd="10dp"/>
            <Spinner
                android:id="@+id/spinnerEditMode"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#FFFFFF" />
        </LinearLayout>

        <!-- Configuración específica del modo -->
        <LinearLayout
            android:id="@+id/layoutModeDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="15dp"
            android:visibility="gone">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchModeEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/config_mode_enabled"
                android:textSize="13sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilModeName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/config_mode_name_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editModeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Columna Izquierda: General -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/lblGeneral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_general"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDefaultFolder"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/config_default_folder"
                    app:hintEnabled="true"
                    app:hintAnimationEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDefaultFolder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:textSize="14sp"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/lblLanguage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_language"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <Spinner
                    android:id="@+id/spinnerLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#BB86FC" />

                <TextView
                    android:id="@+id/lblSeekTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_seek_time"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <SeekBar
                        android:id="@+id/seekBarSkipTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="60"
                        android:progressTint="#BB86FC"
                        android:thumbTint="#BB86FC" />
                    <TextView
                        android:id="@+id/txtValueSeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10s"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNightMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_night_mode"
                    android:textSize="13sp"
                    android:minHeight="40dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPilotMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_pilotMode"
                    android:textSize="13sp"
                    android:minHeight="40dp" />
            </LinearLayout>

            <!-- Columna Derecha: Apariencia -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/lblAppearance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_appearance"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchHideExtension"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_hide_extension"
                    android:textSize="13sp"
                    android:minHeight="40dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTitlePosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/config_title_top"
                    android:textSize="13sp"
                    android:minHeight="40dp" />

                <TextView
                    android:id="@+id/lblTextSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_text_size"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
                <SeekBar
                    android:id="@+id/seekBarTextSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="60"
                    android:progressTint="#BB86FC"
                    android:thumbTint="#BB86FC" />

                <TextView
                    android:id="@+id/lblItemHeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_item_height"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
                <SeekBar
                    android:id="@+id/seekBarItemHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progressTint="#BB86FC"
                    android:thumbTint="#BB86FC" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>